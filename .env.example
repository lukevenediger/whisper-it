# Copy to .env and fill in. Docker-compose auto-loads .env from this directory.
# Nothing here is required for basic transcription -- only set what you need.

# --- Cloud speaker attribution ---
# Uses OpenRouter to call an LLM that names the speakers in a transcript. Optional.
# Enable by setting this to 1
WHISPER_DIARIZE=
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Parakeet v3 (default engine) ---
# Parakeet is the default model. These rarely need changing.
# Whisper model used when a Parakeet request forces a language Parakeet can't do
# (anything outside its 25 European languages -- e.g. Japanese, Chinese, Arabic).
WHISPER_PARAKEET_FALLBACK_MODEL=small
# onnx-asr model id for Parakeet. Override only to pin a different Parakeet build.
WHISPER_PARAKEET_MODEL=nemo-parakeet-tdt-0.6b-v3

# --- Debug mode (dev convenience) ---
# Exposes tests/fixtures/audio/* in a "Run fixture" dropdown in the UI so you can
# kick off transcription against a known file without dragging from your desktop.
# Off in production. Compose mounts tests/fixtures/audio:/fixtures:ro automatically.
WHISPER_DEBUG_FIXTURES=0
