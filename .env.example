# Copy to .env and fill in. Docker-compose auto-loads .env from this directory.
# Nothing here is required for basic transcription -- only set what you need.

# --- On-device speaker diarization (Phase 1) ---
# Runs pyannote.audio 3.1 locally. No data leaves your machine.
#
# Needs a free HuggingFace account:
#   1. Sign up at https://huggingface.co
#   2. Accept terms at https://huggingface.co/pyannote/speaker-diarization-3.1
#   3. Generate a token at https://huggingface.co/settings/tokens (read access is enough)
# HF_TOKEN is the HuggingFace token -- NOT an OpenRouter key. They are unrelated services.
WHISPER_DIARIZE=0
HF_TOKEN=

# --- Cloud speaker attribution with named labels (Phase 2) ---
# Uses OpenRouter to call an LLM that assigns speaker names to segments.
# Optional. Users can also bring their own key in the browser (BYOK) instead of setting this.
# Get one at https://openrouter.ai/keys
# OPENROUTER_API_KEY is the OpenRouter key -- NOT a HuggingFace token.
OPENROUTER_API_KEY=
